#include <stdio.h>
int main()
{
    int n,count=0;
    scanf("%d",&n);
    while(n!=1)
    {
        if(n%2==0)
        {
            count++;
            n=n/2;
        }
        else
        {
            count++;
            n=(n*3)+1;
        }
    }
    printf("%d",count);
    return 0;
    
}
