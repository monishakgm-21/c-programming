#include <stdio.h>

int main()
{
    int n,count=0;
    scanf("%d",&n);
    for(int i=n+1; count<1; i++)
    {
      int ori=i,reverse=0,r,x=i;
      while(x!=0)
      {
          r=x%10;
          reverse=reverse*10+r;
          x=x/10;
      }
      if(ori==reverse)
      {
          printf("%d",i);
          count++;
      }
        
    }

    return 0;
} 
