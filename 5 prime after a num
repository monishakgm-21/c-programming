#include <stdio.h>

int main()
{
    int n,count=0;
    scanf("%d",&n);
    for(int i=n+1; count<5; i++)
    {   int f=0;
        for(int j=1; j<=i; j++)
        {
            if(i%j==0)
            {
                f++;
            }
        }
        if(f==2)
        {
            printf("%d\n",i);
            count++;
        }
    }
    
    return 0;
}
